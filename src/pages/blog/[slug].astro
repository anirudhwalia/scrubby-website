---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostPage from '../../page-components/BlogPostPage.jsx';
import { blogPosts, getAuthorBySlug, getCategoryBySlug } from '../../data/blog.js';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { slug } = Astro.params;
const title = post?.title || 'Blog Post';
const description = post?.excerpt || '';
const author = post?.author ? getAuthorBySlug(post.author) : null;
const category = post?.category ? getCategoryBySlug(post.category) : null;
const postImage = post?.thumbnail || '/og-image.png';

// Article structured data (server-rendered)
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: `https://scrubby.io/blog/${slug}/`,
  datePublished: post?.date || '',
  dateModified: post?.updatedDate || post?.date || '',
  image: postImage.startsWith('http') ? postImage : `https://scrubby.io${postImage}`,
  author: {
    '@type': 'Person',
    name: author?.name || 'Scrubby Team',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Scrubby',
    logo: {
      '@type': 'ImageObject',
      url: 'https://scrubby.io/logos/scrubby-logo.svg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://scrubby.io/blog/${slug}/`,
  },
};

// Breadcrumb schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://scrubby.io/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://scrubby.io/blog/' },
    ...(category ? [{ '@type': 'ListItem', position: 3, name: category.name, item: `https://scrubby.io/blog/category/${category.slug}/` }] : []),
    { '@type': 'ListItem', position: category ? 4 : 3, name: title, item: `https://scrubby.io/blog/${slug}/` },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  path={`/blog/${slug}/`}
  image={postImage}
  ogType="article"
  article={{
    publishedTime: post?.date || '',
    modifiedTime: post?.updatedDate || post?.date || '',
    author: author?.name || 'Scrubby Team',
    section: category?.name || 'Blog',
    tags: post?.tags || [],
  }}
  schema={[articleSchema, breadcrumbSchema]}
>
  <BlogPostPage client:load />
</BaseLayout>
