---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex={true} path="/404/">
  <section class="relative pt-40 pb-24 bg-white overflow-hidden">
    {/* Background dots */}
    <div class="absolute inset-0 dots-bg opacity-40"></div>

    {/* Decorative dots */}
    <div class="absolute top-16 left-16 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse"></div>
    <div class="absolute top-24 right-24 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay: 1s"></div>
    <div class="absolute bottom-20 left-1/3 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay: 2s"></div>
    <div class="absolute bottom-32 right-1/4 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay: 0.5s"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      {/* Large 404 */}
      <h1 class="font-display font-800 text-[8rem] sm:text-[10rem] lg:text-[12rem] leading-none text-gradient mb-2 select-none">
        404
      </h1>

      {/* Heading */}
      <h2 class="font-display font-800 text-3xl sm:text-4xl text-ink mb-4">
        Page Not Found
      </h2>

      {/* Subtitle */}
      <p class="text-ink-secondary text-lg max-w-md mx-auto mb-10 font-body">
        The page you're looking for doesn't exist or has been moved.
      </p>

      {/* Buttons */}
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="btn-primary">
          <!-- Home icon (lucide) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Go Home
        </a>
        <a href="/blog" class="btn-secondary">
          <!-- BookOpen icon (lucide) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
          Visit Blog
          <!-- ArrowRight icon (lucide) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
