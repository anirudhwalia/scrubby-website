---
import BaseLayout from '../layouts/BaseLayout.astro';

const expectations = [
  {
    text: "Personalized walkthrough of Scrubby\u2019s features",
    // Lightbulb icon
    svgPath: 'M9 21h6m-6-3h6M12 3a6 6 0 0 1 6 6c0 2.22-1.21 4.16-3 5.2V18H9v-3.8C7.21 13.16 6 11.22 6 9a6 6 0 0 1 6-6z',
  },
  {
    text: 'Live Q&A with our team',
    // MessageSquare icon
    svgPath: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
  },
  {
    text: 'Custom recommendations for your use case',
    // HelpCircle icon
    svgPath: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zm0-6v.01M12 8a2 2 0 0 0-1.995 1.85L10 10h2a2 2 0 0 1 1.995-1.85L14 8a2 2 0 1 0-4 0',
  },
];
---

<BaseLayout
  title="Demo Booked"
  description="Your demo with the Scrubby team has been booked. We'll send you a confirmation email shortly."
  path="/demo-call-booked"
  noindex
>
  <section class="relative pt-40 pb-24 bg-white overflow-hidden">
    <div class="absolute inset-0 dots-bg opacity-40"></div>

    <div class="relative z-10 max-w-2xl mx-auto px-6 text-center">

      <!-- Green checkmark -->
      <div class="w-20 h-20 mx-auto rounded-full bg-brand-green-bg flex items-center justify-center mb-8">
        <!-- CheckCircle2 icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-green-dark"
        >
          <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" />
          <path d="m9 12 2 2 4-4" />
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="font-display font-800 text-3xl sm:text-4xl text-ink mb-4">
        Your Demo is Booked!
      </h1>

      <!-- Message -->
      <p class="text-ink-secondary text-lg max-w-lg mx-auto mb-12 font-body leading-relaxed">
        Thank you for scheduling a demo with our team. You'll receive a
        confirmation email shortly with all the details.
      </p>

      <!-- What to expect -->
      <div class="card p-8 md:p-10 text-left max-w-lg mx-auto mb-10">
        <h2 class="font-display font-700 text-lg text-ink mb-6">
          What to expect
        </h2>

        <div class="space-y-5">
          {expectations.map((item) => (
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-brand-green-bg flex items-center justify-center flex-shrink-0">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-brand-green-dark"
                >
                  <path d={item.svgPath} />
                </svg>
              </div>
              <p class="text-sm text-ink-secondary font-body leading-relaxed pt-2">
                {item.text}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- Back to Home button -->
      <a href="/" class="btn-primary">
        <!-- Home icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        Back to Home
        <!-- ArrowRight icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>

    </div>
  </section>
</BaseLayout>
