---
import BaseLayout from '../../layouts/BaseLayout.astro';

const comparisonRows = [
  { feature: 'Primary Focus', mailchimp: 'Email marketing & campaign automation', scrubby: 'Risky / catch-all email validation' },
  { feature: 'Core Strength', mailchimp: 'Audience management & marketing tools', scrubby: '98.7% deliverability on risky emails' },
  { feature: 'Email Verification', mailchimp: 'Basic list hygiene (Omnivore)', scrubby: 'Deep inbox-level catch-all validation' },
  { feature: 'Campaign Tools', mailchimp: 'Templates, automation, A/B testing', scrubby: 'Not applicable (validation tool)' },
  { feature: 'Catch-All Handling', mailchimp: 'Cannot detect catch-all emails', scrubby: 'Validates each catch-all individually' },
  { feature: 'Bounce Management', mailchimp: 'Suspends account at 2%+ bounce rate', scrubby: 'Prevents bounces before they happen' },
  { feature: 'Pricing', mailchimp: 'Free tier + paid plans from $13/mo', scrubby: 'Starting at $27/mo, 100 free credits' },
  { feature: 'Best For', mailchimp: 'Sending marketing campaigns', scrubby: 'Cleaning lists before Mailchimp import' },
];

const keyDifferences = [
  {
    iconName: 'mail',
    title: 'Marketing vs Validation',
    description: 'Mailchimp is an email marketing platform for creating and sending campaigns with templates, automation, and analytics. Scrubby is a validation specialist that cleans your list before import, preventing the bounces that can get your Mailchimp account suspended.',
  },
  {
    iconName: 'shield',
    title: 'Bounce Rate Protection',
    description: 'Mailchimp enforces strict bounce rate limits and can suspend accounts exceeding 2%. Scrubby validates risky emails before you import them, keeping your bounce rate low and your Mailchimp account in good standing.',
  },
  {
    iconName: 'bar-chart',
    title: 'List Quality Assurance',
    description: "Mailchimp's built-in Omnivore tool catches obvious invalids, but catch-all domain emails pass through undetected. Scrubby catches what Omnivore misses, validating those hidden risky addresses that cause unexpected bounces.",
  },
];

const workflowSteps = [
  {
    step: '01',
    iconName: 'arrow-down-right',
    title: 'Export Mailchimp List',
    description: 'Export your Mailchimp audience list, focusing on contacts that have not been recently verified or have low engagement.',
  },
  {
    step: '02',
    iconName: 'shield',
    title: 'Validate with Scrubby',
    description: 'Upload your list to Scrubby for deep inbox-level validation. Identify risky catch-all emails that could cause bounces.',
  },
  {
    step: '03',
    iconName: 'refresh-cw',
    title: 'Clean Your List',
    description: 'Remove the invalid emails Scrubby identifies. Keep only verified addresses that will reach real inboxes.',
  },
  {
    step: '04',
    iconName: 'sparkles',
    title: 'Re-import Clean List',
    description: 'Import your Scrubby-validated clean list back into Mailchimp. Send campaigns with confidence and protect your sender reputation.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Scrubby vs Mailchimp — Email Validation Comparison",
  "description": "Compare Scrubby and Mailchimp for email validation. See how Scrubby complements Mailchimp to validate catch-all and risky emails with 98.7% accuracy.",
  "url": "https://scrubby.io/alternatives/mailchimp"
};
---

<BaseLayout
  title="Scrubby vs Mailchimp — Email Validation Comparison"
  description="Compare Scrubby and Mailchimp for email validation. See how Scrubby complements Mailchimp to validate catch-all and risky emails with 98.7% accuracy."
  path="/alternatives/mailchimp"
  schema={schema}
>
  <main>

    <!-- ═══════════════════════════════════════════════════════
         HERO SECTION
         ═══════════════════════════════════════════════════════ -->
    <section class="relative pt-40 pb-28 overflow-hidden" style="background: #18181B;">
      <div
        class="absolute w-[600px] h-[600px] -top-40 -left-40 rounded-full blur-3xl animate-pulse opacity-60"
        style="background: rgba(45, 206, 142, 0.08);"
      ></div>
      <div
        class="absolute w-[400px] h-[400px] top-20 right-0 rounded-full blur-3xl animate-pulse"
        style="background: rgba(45, 206, 142, 0.05); animation-delay: 2s;"
      ></div>
      <div class="absolute inset-0 grid-bg opacity-40"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
        <div class="reveal">
          <div class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-display font-600 tracking-wide bg-brand-green/10 border border-brand-green/20 text-brand-green mb-8">
            <!-- Zap icon -->
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
            Scrubby + Mailchimp
          </div>

          <h1 class="font-display font-800 text-4xl sm:text-5xl lg:text-[3.75rem] leading-[1.08] tracking-tight mb-6 max-w-4xl mx-auto">
            <span class="text-white">Mailchimp + Scrubby: </span>
            <span class="text-gradient-light">Better Together</span>
          </h1>

          <p class="text-lg sm:text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto mb-10 font-body">
            Mailchimp powers your email marketing. Scrubby cleans your lists before import,
            preventing bounces that damage your sender reputation and risk account suspension.
          </p>

          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="https://app.scrubby.io" class="btn-primary text-base px-8 py-4">
              Try Scrubby Free
              <!-- ArrowRight icon -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <a href="/how-it-works" class="btn-secondary-dark text-base px-8 py-4">
              How It Works
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         COMPARISON TABLE SECTION
         ═══════════════════════════════════════════════════════ -->
    <section class="relative py-24 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16 reveal">
          <div class="badge mx-auto mb-5">
            <!-- Layers icon -->
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 2 7 12 12 22 7 12 2"/>
              <polyline points="2 17 12 22 22 17"/>
              <polyline points="2 12 12 17 22 12"/>
            </svg>
            Feature Comparison
          </div>
          <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-ink mb-5">
            How They <span class="text-gradient">Compare</span>
          </h2>
          <p class="text-ink-secondary text-lg max-w-2xl mx-auto leading-relaxed font-body">
            Mailchimp is an email marketing platform while Scrubby is an email validation specialist.
            They serve different but complementary roles in your marketing stack.
          </p>
        </div>

        <div class="reveal">
          <div class="card overflow-hidden">
            <!-- Table Header -->
            <div class="grid grid-cols-3 border-b border-surface-border">
              <div class="px-6 py-4 text-[11px] font-display font-600 text-ink-muted uppercase tracking-wider">
                Feature
              </div>
              <div class="px-6 py-4 text-[11px] font-display font-600 text-ink-muted uppercase tracking-wider text-center bg-surface-secondary/50">
                Mailchimp
              </div>
              <div class="px-6 py-4 text-[11px] font-display font-600 uppercase tracking-wider text-center" style="background: rgba(45,206,142,0.05); color: #1BA872;">
                Scrubby
              </div>
            </div>

            <!-- Table Rows -->
            {comparisonRows.map((row, i) => (
              <div
                class={`grid grid-cols-3 ${i < comparisonRows.length - 1 ? 'border-b border-surface-border/50' : ''} hover:bg-surface-secondary/30 transition-colors`}
              >
                <div class="px-6 py-4 text-sm font-display font-600 text-ink">
                  {row.feature}
                </div>
                <div class="px-6 py-4 text-sm text-ink-secondary font-body text-center bg-surface-secondary/20">
                  {row.mailchimp}
                </div>
                <div class="px-6 py-4 text-sm text-ink-secondary font-body text-center" style="background: rgba(45,206,142,0.02);">
                  {row.scrubby}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         KEY DIFFERENCES SECTION
         ═══════════════════════════════════════════════════════ -->
    <section class="relative py-24 bg-surface-secondary">
      <div class="divider mb-24"></div>

      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16 reveal">
          <div class="badge mx-auto mb-5">
            <!-- Target icon -->
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
            Key Differences
          </div>
          <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-ink mb-5">
            What Sets Them <span class="text-gradient">Apart</span>
          </h2>
          <p class="text-ink-secondary text-lg max-w-2xl mx-auto leading-relaxed font-body">
            Mailchimp and Scrubby are different tools that work powerfully together.
            Understanding their strengths helps you maximize your email marketing.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {keyDifferences.map((diff, i) => (
            <div
              class="card p-8 reveal group"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <div class="w-14 h-14 rounded-2xl bg-brand-green-bg flex items-center justify-center mb-6 group-hover:shadow-green-glow transition-shadow duration-300">
                {diff.iconName === 'mail' && (
                  <!-- Mail icon -->
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                )}
                {diff.iconName === 'shield' && (
                  <!-- Shield icon -->
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                )}
                {diff.iconName === 'bar-chart' && (
                  <!-- BarChart3 icon -->
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                  </svg>
                )}
              </div>
              <h3 class="font-display font-700 text-xl text-ink mb-3">
                {diff.title}
              </h3>
              <p class="text-sm text-ink-tertiary leading-relaxed font-body">
                {diff.description}
              </p>
            </div>
          ))}
        </div>
      </div>

      <div class="divider mt-24"></div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         RECOMMENDED WORKFLOW SECTION
         ═══════════════════════════════════════════════════════ -->
    <section class="relative py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16 reveal">
          <div class="badge mx-auto mb-5">
            <!-- RefreshCw icon -->
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"/>
              <polyline points="1 20 1 14 7 14"/>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
            Recommended Workflow
          </div>
          <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-ink mb-5">
            Use Them <span class="text-gradient">Together</span>
          </h2>
          <p class="text-ink-secondary text-lg max-w-2xl mx-auto leading-relaxed font-body">
            Clean your lists with Scrubby before importing into Mailchimp.
            Protect your sender reputation and keep your account in good standing.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
          {workflowSteps.map((step, i) => (
            <div
              class="card p-7 reveal text-center relative group"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <div class="text-5xl font-display font-800 text-surface-tertiary mb-4 group-hover:text-brand-green/20 transition-colors duration-300">
                {step.step}
              </div>

              <div class="w-12 h-12 mx-auto rounded-xl bg-brand-green-bg flex items-center justify-center mb-4">
                {step.iconName === 'arrow-down-right' && (
                  <!-- ArrowDownRight icon -->
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark">
                    <line x1="7" y1="7" x2="17" y2="17"/>
                    <polyline points="17 7 17 17 7 17"/>
                  </svg>
                )}
                {step.iconName === 'shield' && (
                  <!-- Shield icon -->
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                )}
                {step.iconName === 'refresh-cw' && (
                  <!-- RefreshCw icon -->
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark">
                    <polyline points="23 4 23 10 17 10"/>
                    <polyline points="1 20 1 14 7 14"/>
                    <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                  </svg>
                )}
                {step.iconName === 'sparkles' && (
                  <!-- Sparkles icon -->
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark">
                    <path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z"/>
                    <path d="M19 11l.75 2.25L22 14l-2.25.75L19 17l-.75-2.25L16 14l2.25-.75L19 11z"/>
                    <path d="M5 17l.5 1.5L7 19l-1.5.5L5 21l-.5-1.5L3 19l1.5-.5L5 17z"/>
                  </svg>
                )}
              </div>

              <h3 class="font-display font-700 text-lg text-ink mb-2">
                {step.title}
              </h3>
              <p class="text-sm text-ink-tertiary leading-relaxed font-body">
                {step.description}
              </p>

              {i < workflowSteps.length - 1 && (
                <div class="hidden lg:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10">
                  <!-- ArrowRight icon -->
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-muted">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         CTA SECTION
         ═══════════════════════════════════════════════════════ -->
    <section class="relative py-24 overflow-hidden bg-white">
      <div class="divider mb-24"></div>

      <div class="relative max-w-4xl mx-auto px-6">
        <div class="reveal">
          <div class="rounded-2xl p-10 md:p-16 text-center relative overflow-hidden" style="background: #18181B;">
            <div class="absolute inset-0 grid-bg opacity-30"></div>

            <div class="absolute top-8 left-8 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse"></div>
            <div class="absolute top-12 right-16 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay: 1s;"></div>
            <div class="absolute bottom-16 left-20 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay: 2s;"></div>
            <div class="absolute bottom-8 right-8 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay: 0.5s;"></div>

            <div class="relative z-10">
              <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-display font-600 tracking-wide bg-brand-green/10 border border-brand-green/20 text-brand-green mb-6">
                <!-- Zap icon -->
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Get Started
              </div>

              <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-white mb-5 leading-tight">
                Try Scrubby <span class="text-gradient-light">Free</span>
              </h2>

              <p class="text-slate-300 text-lg max-w-xl mx-auto mb-10 font-body">
                Start with 100 free credits. Clean your Mailchimp list and prevent
                the bounces that damage your sender reputation and risk account suspension.
              </p>

              <div class="flex flex-wrap items-center justify-center gap-4 mb-10">
                <a href="https://app.scrubby.io" class="btn-primary text-base px-8 py-4">
                  Start Free Trial
                  <!-- ArrowRight icon -->
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
                <a href="/pricing" class="btn-secondary-dark text-base px-8 py-4">
                  View Pricing
                </a>
              </div>

              <div class="flex flex-wrap items-center justify-center gap-6 text-xs text-slate-400 font-display font-500">
                <div class="flex items-center gap-1.5">
                  <!-- CheckCircle2 icon -->
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  100 Free Credits
                </div>
                <div class="flex items-center gap-1.5">
                  <!-- CheckCircle2 icon -->
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  No Credit Card Required
                </div>
                <div class="flex items-center gap-1.5">
                  <!-- CheckCircle2 icon -->
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  98.7% Accuracy
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  // Intersection Observer for reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
