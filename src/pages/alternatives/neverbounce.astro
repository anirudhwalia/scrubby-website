---
import BaseLayout from '../../layouts/BaseLayout.astro';

const comparisonRows = [
  { feature: 'Primary Focus', neverbounce: 'Email list verification & cleaning', scrubby: 'Risky / catch-all email validation' },
  { feature: 'Accuracy Rate', neverbounce: '99.9% deliverability guarantee', scrubby: '98.7% deliverability on risky emails' },
  { feature: 'Processing Speed', neverbounce: 'Real-time & bulk (seconds)', scrubby: '48-72 hours (deep inbox-level checks)' },
  { feature: 'Free Credits', neverbounce: '10 free verification credits', scrubby: '100 free verification credits' },
  { feature: 'Integrations', neverbounce: '80+ platform integrations', scrubby: 'API + major platforms (Zapier, HubSpot)' },
  { feature: 'Catch-All Handling', neverbounce: 'Flags as "Accept All" (unresolved)', scrubby: 'Validates each address individually' },
  { feature: 'Result Categories', neverbounce: 'Valid / Invalid / Disposable / Accept All', scrubby: 'Valid / Invalid (definitive results)' },
  { feature: 'Best For', neverbounce: 'Rapid list cleaning at scale', scrubby: 'Recovering leads from risky segments' },
];

const keyDifferences = [
  {
    title: 'Accept-All Resolution',
    description: 'NeverBounce categorizes emails as Valid, Invalid, Disposable, or Accept All. Scrubby takes those "Accept All" addresses and revalidates them at the inbox level, turning unknowns into definitive results.',
    icon: 'layers',
  },
  {
    title: 'Speed vs Depth',
    description: 'NeverBounce delivers results in seconds with rapid SMTP checks, ideal for real-time verification. Scrubby takes 48-72 hours but performs deep inbox-level validation that catches what fast checks miss.',
    icon: 'clock',
  },
  {
    title: 'Complementary Coverage',
    description: 'NeverBounce excels at rapid list processing and removing obvious invalids. Scrubby specializes in the grey area: the 30-40% of emails that standard tools cannot definitively classify.',
    icon: 'target',
  },
];

const workflowSteps = [
  {
    step: '01',
    title: 'Clean with NeverBounce',
    description: 'Upload your list to NeverBounce for rapid verification. Remove invalid, disposable, and duplicate emails from your list.',
    icon: 'refresh',
  },
  {
    step: '02',
    title: 'Export Risky Emails',
    description: 'Filter and export the "Accept All" and risky emails that NeverBounce could not definitively verify.',
    icon: 'arrow-down-right',
  },
  {
    step: '03',
    title: 'Validate with Scrubby',
    description: 'Send the risky segment to Scrubby for deep inbox-level validation. Within 48-72 hours, recover verified leads.',
    icon: 'shield',
  },
  {
    step: '04',
    title: 'Deploy Clean Lists',
    description: 'Merge NeverBounce valid emails with Scrubby-validated emails. Launch campaigns with maximum deliverability and zero wasted leads.',
    icon: 'sparkles',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Scrubby vs NeverBounce — Email Validation Comparison",
  "description": "Compare Scrubby and NeverBounce for email validation. See how Scrubby complements NeverBounce to validate catch-all and risky emails with 98.7% accuracy.",
  "url": "https://scrubby.io/alternatives/neverbounce"
};
---

<BaseLayout
  title="Scrubby vs NeverBounce — Email Validation Comparison"
  description="Compare Scrubby and NeverBounce for email validation. See how Scrubby complements NeverBounce to validate catch-all and risky emails with 98.7% accuracy."
  path="/alternatives/neverbounce"
  schema={schema}
>

  <!-- ═══════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════ -->
  <section class="relative pt-40 pb-28 overflow-hidden" style="background:#18181B;">
    <div
      class="absolute w-[600px] h-[600px] -top-40 -left-40 rounded-full blur-3xl animate-pulse opacity-60"
      style="background:rgba(45,206,142,0.08);"
    ></div>
    <div
      class="absolute w-[400px] h-[400px] top-20 right-0 rounded-full blur-3xl animate-pulse"
      style="background:rgba(45,206,142,0.05);animation-delay:2s;"
    ></div>
    <div class="absolute inset-0 grid-bg opacity-40"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <div class="reveal">
        <div class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-display font-600 tracking-wide bg-brand-green/10 border border-brand-green/20 text-brand-green mb-8">
          <!-- Zap icon -->
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
          Scrubby vs NeverBounce
        </div>

        <h1 class="font-display font-800 text-4xl sm:text-5xl lg:text-[3.75rem] leading-[1.08] tracking-tight mb-6 max-w-4xl mx-auto">
          <span class="text-white">NeverBounce + Scrubby: </span>
          <span class="text-gradient-light">Better Together</span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto mb-10 font-body">
          NeverBounce is great at rapid list cleaning. Scrubby picks up where it leaves off,
          validating the risky and catch-all emails that NeverBounce marks as &quot;Accept All.&quot;
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="https://app.scrubby.io" class="btn-primary text-base px-8 py-4">
            Try Scrubby Free
            <!-- ArrowRight icon -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a href="/how-it-works" class="btn-secondary-dark text-base px-8 py-4">
            How It Works
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       COMPARISON TABLE
       ═══════════════════════════════════════════════════════ -->
  <section class="relative py-24 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <div class="badge mx-auto mb-5">
          <!-- Layers icon -->
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
            <polyline points="2 17 12 22 22 17"></polyline>
            <polyline points="2 12 12 17 22 12"></polyline>
          </svg>
          Feature Comparison
        </div>
        <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-ink mb-5">
          How They <span class="text-gradient">Compare</span>
        </h2>
        <p class="text-ink-secondary text-lg max-w-2xl mx-auto leading-relaxed font-body">
          NeverBounce and Scrubby serve different stages of the email validation pipeline.
          Here is a side-by-side look at what each tool does best.
        </p>
      </div>

      <div class="reveal">
        <div class="card overflow-hidden">
          <!-- Table Header -->
          <div class="grid grid-cols-3 border-b border-surface-border">
            <div class="px-6 py-4 text-[11px] font-display font-600 text-ink-muted uppercase tracking-wider">
              Feature
            </div>
            <div class="px-6 py-4 text-[11px] font-display font-600 text-ink-muted uppercase tracking-wider text-center bg-surface-secondary/50">
              NeverBounce
            </div>
            <div class="px-6 py-4 text-[11px] font-display font-600 uppercase tracking-wider text-center" style="background:rgba(45,206,142,0.05);color:#1BA872;">
              Scrubby
            </div>
          </div>

          <!-- Table Rows -->
          {comparisonRows.map((row, i) => (
            <div
              class={`grid grid-cols-3 ${i < comparisonRows.length - 1 ? 'border-b border-surface-border/50' : ''} hover:bg-surface-secondary/30 transition-colors`}
            >
              <div class="px-6 py-4 text-sm font-display font-600 text-ink">
                {row.feature}
              </div>
              <div class="px-6 py-4 text-sm text-ink-secondary font-body text-center bg-surface-secondary/20">
                {row.neverbounce}
              </div>
              <div class="px-6 py-4 text-sm text-ink-secondary font-body text-center" style="background:rgba(45,206,142,0.02);">
                {row.scrubby}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       KEY DIFFERENCES
       ═══════════════════════════════════════════════════════ -->
  <section class="relative py-24 bg-surface-secondary">
    <div class="divider mb-24"></div>

    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <div class="badge mx-auto mb-5">
          <!-- Target icon -->
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="6"></circle>
            <circle cx="12" cy="12" r="2"></circle>
          </svg>
          Key Differences
        </div>
        <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-ink mb-5">
          What Sets Them <span class="text-gradient">Apart</span>
        </h2>
        <p class="text-ink-secondary text-lg max-w-2xl mx-auto leading-relaxed font-body">
          Understanding the core differences helps you use both tools effectively
          to maximize your email deliverability.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {keyDifferences.map((diff, i) => (
          <div
            class="card p-8 reveal group"
            style={`transition-delay:${i * 0.1}s;`}
          >
            <div class="w-14 h-14 rounded-2xl bg-brand-green-bg flex items-center justify-center mb-6 group-hover:shadow-green-glow transition-shadow duration-300">
              {diff.icon === 'layers' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark" aria-hidden="true">
                  <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                  <polyline points="2 17 12 22 22 17"></polyline>
                  <polyline points="2 12 12 17 22 12"></polyline>
                </svg>
              )}
              {diff.icon === 'clock' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              )}
              {diff.icon === 'target' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"></circle>
                  <circle cx="12" cy="12" r="6"></circle>
                  <circle cx="12" cy="12" r="2"></circle>
                </svg>
              )}
            </div>
            <h3 class="font-display font-700 text-xl text-ink mb-3">
              {diff.title}
            </h3>
            <p class="text-sm text-ink-tertiary leading-relaxed font-body">
              {diff.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    <div class="divider mt-24"></div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       RECOMMENDED WORKFLOW
       ═══════════════════════════════════════════════════════ -->
  <section class="relative py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <div class="badge mx-auto mb-5">
          <!-- RefreshCw icon -->
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="23 4 23 10 17 10"></polyline>
            <polyline points="1 20 1 14 7 14"></polyline>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
          </svg>
          Recommended Workflow
        </div>
        <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-ink mb-5">
          Use Them <span class="text-gradient">Together</span>
        </h2>
        <p class="text-ink-secondary text-lg max-w-2xl mx-auto leading-relaxed font-body">
          The best results come from combining NeverBounce&apos;s speed with Scrubby&apos;s depth.
          Here is the recommended workflow.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        {workflowSteps.map((step, i) => (
          <div
            class="card p-7 reveal text-center relative group"
            style={`transition-delay:${i * 0.1}s;`}
          >
            <!-- Step number -->
            <div class="text-5xl font-display font-800 text-surface-tertiary mb-4 group-hover:text-brand-green/20 transition-colors duration-300">
              {step.step}
            </div>

            <div class="w-12 h-12 mx-auto rounded-xl bg-brand-green-bg flex items-center justify-center mb-4">
              {step.icon === 'refresh' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark" aria-hidden="true">
                  <polyline points="23 4 23 10 17 10"></polyline>
                  <polyline points="1 20 1 14 7 14"></polyline>
                  <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                </svg>
              )}
              {step.icon === 'arrow-down-right' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark" aria-hidden="true">
                  <line x1="7" y1="7" x2="17" y2="17"></line>
                  <polyline points="17 7 17 17 7 17"></polyline>
                </svg>
              )}
              {step.icon === 'shield' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              )}
              {step.icon === 'sparkles' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green-dark" aria-hidden="true">
                  <path d="M12 3L13.5 8.5L19 10L13.5 11.5L12 17L10.5 11.5L5 10L10.5 8.5L12 3Z"></path>
                  <path d="M5 3L5.75 5.25L8 6L5.75 6.75L5 9L4.25 6.75L2 6L4.25 5.25L5 3Z"></path>
                  <path d="M19 14L19.75 16.25L22 17L19.75 17.75L19 20L18.25 17.75L16 17L18.25 16.25L19 14Z"></path>
                </svg>
              )}
            </div>

            <h3 class="font-display font-700 text-lg text-ink mb-2">
              {step.title}
            </h3>
            <p class="text-sm text-ink-tertiary leading-relaxed font-body">
              {step.description}
            </p>

            <!-- Connector arrow (not on last) -->
            {i < workflowSteps.length - 1 && (
              <div class="hidden lg:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-muted" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════════════════ -->
  <section class="relative py-24 overflow-hidden bg-white">
    <div class="divider mb-24"></div>

    <div class="relative max-w-4xl mx-auto px-6">
      <div class="reveal">
        <div class="rounded-2xl p-10 md:p-16 text-center relative overflow-hidden" style="background:#18181B;">
          <div class="absolute inset-0 grid-bg opacity-30"></div>

          <div class="absolute top-8 left-8 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse"></div>
          <div class="absolute top-12 right-16 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay:1s;"></div>
          <div class="absolute bottom-16 left-20 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay:2s;"></div>
          <div class="absolute bottom-8 right-8 w-2 h-2 rounded-full bg-brand-green/40 animate-pulse" style="animation-delay:0.5s;"></div>

          <div class="relative z-10">
            <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-display font-600 tracking-wide bg-brand-green/10 border border-brand-green/20 text-brand-green mb-6">
              <!-- Zap icon -->
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
              </svg>
              Get Started
            </div>

            <h2 class="font-display font-800 text-3xl sm:text-4xl lg:text-5xl text-white mb-5 leading-tight">
              Try Scrubby <span class="text-gradient-light">Free</span>
            </h2>

            <p class="text-slate-300 text-lg max-w-xl mx-auto mb-10 font-body">
              Start with 100 free credits. Validate your risky emails and see how many
              leads you can recover from your NeverBounce &quot;Accept All&quot; list.
            </p>

            <div class="flex flex-wrap items-center justify-center gap-4 mb-10">
              <a href="https://app.scrubby.io" class="btn-primary text-base px-8 py-4">
                Start Free Trial
                <!-- ArrowRight icon -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
              <a href="/pricing" class="btn-secondary-dark text-base px-8 py-4">
                View Pricing
              </a>
            </div>

            <div class="flex flex-wrap items-center justify-center gap-6 text-xs text-slate-400 font-display font-500">
              <div class="flex items-center gap-1.5">
                <!-- CheckCircle2 icon -->
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                100 Free Credits
              </div>
              <div class="flex items-center gap-1.5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                No Credit Card Required
              </div>
              <div class="flex items-center gap-1.5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-green" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                98.7% Accuracy
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
